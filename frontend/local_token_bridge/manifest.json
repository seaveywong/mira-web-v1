{
  "manifest_version": 3,
  "name": "Mira 本地 API 执行器",
  "version": "2.4.4",
  "description": "Mira 本地执行器。本地执行 Graph API 写操作，Mira 下发任务接收结果。不上传 Cookie/Token。",
  "action": {
    "default_title": "Mira 本地 API 执行器",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "cookies",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "https://shouhu.asia/*",
    "https://graph.facebook.com/*",
    "https://adsmanager-graph.facebook.com/*",
    "*://*.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
