{
  "manifest_version": 3,
  "name": "Mira Local API Executor",
  "version": "2.4.7",
  "description": "Mira local executor. Runs approved local browser tasks and returns task results to Mira.",
  "action": {
    "default_title": "Mira Local API Executor",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "cookies",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "https://shouhu.asia/*",
    "https://graph.facebook.com/*",
    "https://adsmanager-graph.facebook.com/*",
    "*://*.facebook.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
