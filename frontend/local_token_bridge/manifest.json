{
  "manifest_version": 3,
  "name": "Mira 本地 Token",
  "version": "1.1.0",
  "description": "用户显式授权后，将本地 Meta Token 自动上报到 Mira，用于短时铺广告任务。",
  "action": {
    "default_title": "Mira 本地 Token",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "identity",
    "identity.email",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://graph.facebook.com/*",
    "https://www.facebook.com/*"
  ]
}
