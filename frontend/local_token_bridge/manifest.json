{
  "manifest_version": 3,
  "name": "Mira 本地执行器",
  "version": "1.2.0",
  "description": "绑定 Mira 后，在本机已登录 Chrome 中执行广告后台任务，不上传 Cookie 或隐藏凭证。",
  "action": {
    "default_title": "Mira 本地执行器",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "alarms",
    "identity",
    "identity.email",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://graph.facebook.com/*",
    "https://www.facebook.com/*"
  ]
}
